{
  "name": "gsf-investor",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "env -u AUTH_URL -u VERCEL -u VERCEL_ENV -u VERCEL_URL AUTH_URL=http://localhost:3000 next dev",
    "dev:preview": "env -u AUTH_URL -u VERCEL -u VERCEL_ENV -u VERCEL_URL AUTH_URL=http://localhost:3000 DEV_PREVIEW_AUTH=true NEXT_PUBLIC_DEV_PREVIEW_AUTH=true TURSO_DATABASE_URL=file:local.db next dev",
    "db:dev:setup": "node scripts/dev-setup.mjs",
    "db:views": "node scripts/db-views.mjs",
    "db:wealth-schema": "node scripts/apply_wealth_schema.mjs",
    "design:capture": "node scripts/capture-design.mjs",
    "ag:session:start": "bash scripts/ag_session_start.sh",
    "ag:session:checkpoint": "bash scripts/ag_session_checkpoint.sh",
    "ag:session:rollback": "bash scripts/ag_session_rollback.sh",
    "ag:session:status": "bash scripts/ag_session_status.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --quiet",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@libsql/client": "^0.17.3",
    "@sentry/nextjs": "^10.53.1",
    "@tailwindcss/typography": "^0.5.19",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
